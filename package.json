{
  "name": "emp-dashboard-root",
  "version": "1.0.0",
  "description": "Enterprise Employee Management Dashboard",
  "author": "EMP PRO Team",
  "main": "electron.js",
  "scripts": {
    "frontend:dev": "npm run dev --prefix frontend",
    "backend:dev": "npm run dev --prefix backend",
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "build": "npm run build --prefix frontend",
    "electron": "electron .",
    "desktop": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\" \"wait-on http://localhost:5173 && electron .\"",
    "dist": "npm run build && electron-builder",
    "clean-dist": "taskkill /F /IM \"EMP PRO.exe\" /T /FI \"STATUS eq RUNNING\" & if exist dist_electron rmdir /s /q dist_electron && npm run dist"
  },
  "build": {
    "appId": "com.emp.dashboard",
    "productName": "EMP PRO",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "frontend/dist/**/*",
      "electron.js",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  }
}